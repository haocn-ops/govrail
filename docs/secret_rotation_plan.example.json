{
  "tenant_id": "tenant_acme",
  "deploy_env": "staging",
  "rotation_window": "2026-04-01T10:00:00Z/2026-04-01T12:00:00Z",
  "owner": "platform",
  "notes": "Rotate provider secrets without changing request auth logic.",
  "provider_updates": [
    {
      "tool_provider_id": "tp_email",
      "provider_type": "mcp_server",
      "current_auth_ref": "bearer:MCP_API_TOKEN",
      "next_auth_ref": "bearer:MCP_API_TOKEN_V2",
      "secret_binding_name": "MCP_API_TOKEN_V2",
      "cutover_verify_command": "BASE_URL=\"https://<worker>\" TENANT_ID=\"tenant_acme\" VERIFY_OUTPUT_PATH=\"/tmp/secret-rotation-verify.json\" npm run post-deploy:verify"
    },
    {
      "tool_provider_id": "tp_remote_agent",
      "provider_type": "http_api",
      "current_auth_ref": "header:X-Api-Key:A2A_SHARED_KEY",
      "next_auth_ref": "header:X-Api-Key:A2A_SHARED_KEY_V2",
      "secret_binding_name": "A2A_SHARED_KEY_V2",
      "cutover_verify_command": "BASE_URL=\"https://<worker>\" TENANT_ID=\"tenant_acme\" VERIFY_OUTPUT_PATH=\"/tmp/secret-rotation-verify.json\" npm run post-deploy:verify"
    }
  ],
  "secret_commands": [
    "wrangler secret put MCP_API_TOKEN_V2 --env staging",
    "wrangler secret put A2A_SHARED_KEY_V2 --env staging"
  ],
  "rollback": {
    "revert_auth_refs": [
      "bearer:MCP_API_TOKEN",
      "header:X-Api-Key:A2A_SHARED_KEY"
    ],
    "delete_new_secret_after_revert": false
  }
}
