{
  "dashboard_id": "acp_ops_v1",
  "title": "Govrail - Operations Dashboard",
  "description": "Monitoring-system-agnostic dashboard template for staging or production. Wire these panels to logs, synthetic checks, or metrics in your platform of choice.",
  "service": "govrail-control-plane",
  "recommended_refresh_interval_seconds": 60,
  "integration_contract": {
    "manifest_path": "docs/observability_integration_manifest.example.json",
    "required_runtime_inputs": [
      "BASE_URL",
      "TENANT_ID",
      "OBS_SYNTH_SUBJECT",
      "OBS_SYNTH_ROLES"
    ]
  },
  "sections": [
    {
      "name": "Golden Signals",
      "panels": [
        {
          "panel_id": "golden_health_success_rate",
          "name": "Health success rate",
          "type": "timeseries",
          "source": "synthetic_check",
          "query": "GET /api/v1/health success rate",
          "goal": "99.9% over 1h",
          "alert_threshold": "below 99.5% over 5m",
          "synthetic_check_ref": "health_global",
          "alert_rule_ref": "health_5xx_burst"
        },
        {
          "panel_id": "golden_run_create_success_rate",
          "name": "Run create success rate",
          "type": "timeseries",
          "source": "api_logs",
          "query": "POST /api/v1/runs 2xx rate",
          "goal": "99% over 1h",
          "alert_threshold": "5xx above 1% over 10m",
          "alert_rule_ref": "run_create_error_burst"
        },
        {
          "panel_id": "golden_run_completion_rate",
          "name": "Run completion rate",
          "type": "timeseries",
          "source": "d1",
          "query": "completed runs / all terminal runs",
          "goal": "stable upward trend",
          "alert_threshold": "failed ratio above 10% over 30m",
          "alert_rule_ref": "workflow_failure_spike"
        },
        {
          "panel_id": "golden_request_latency_p95",
          "name": "Request latency p95",
          "type": "timeseries",
          "source": "api_logs",
          "query": "p95 latency for northbound requests",
          "goal": "baseline under SLO",
          "alert_threshold": "sustained regression above baseline",
          "owner": "platform-oncall"
        }
      ]
    },
    {
      "name": "Workflow Health",
      "panels": [
        {
          "panel_id": "workflow_pending_approvals",
          "name": "Pending approvals",
          "type": "single_value",
          "source": "d1",
          "query": "count of approvals where status = pending",
          "alert_threshold": "oldest pending approval over 30m"
        },
        {
          "panel_id": "workflow_approval_timeout_ratio",
          "name": "Approval timeout ratio",
          "type": "timeseries",
          "source": "audit_events",
          "query": "approval_expired / approval_created",
          "alert_threshold": "above 10% over 1h",
          "alert_rule_ref": "approval_timeout_ratio_high"
        },
        {
          "panel_id": "workflow_failures",
          "name": "Workflow failures",
          "type": "timeseries",
          "source": "d1",
          "query": "failed runs / terminal runs",
          "alert_threshold": "above 10% over 30m",
          "alert_rule_ref": "workflow_failure_spike"
        }
      ]
    },
    {
      "name": "Gateway Health",
      "panels": [
        {
          "panel_id": "gateway_a2a_inbound_errors",
          "name": "A2A inbound errors",
          "type": "timeseries",
          "source": "api_logs",
          "query": "POST /api/v1/a2a/message:send 5xx rate",
          "alert_threshold": "above 1% over 10m"
        },
        {
          "panel_id": "gateway_mcp_call_errors",
          "name": "MCP call errors",
          "type": "timeseries",
          "source": "api_logs",
          "query": "POST /api/v1/mcp/* 5xx rate",
          "alert_threshold": "above 1% over 10m",
          "alert_rule_ref": "mcp_call_error_burst"
        },
        {
          "panel_id": "gateway_upstream_auth_errors",
          "name": "Upstream auth errors",
          "type": "timeseries",
          "source": "api_logs",
          "query": "upstream_auth_invalid + upstream_auth_not_configured",
          "alert_threshold": "any unexpected non-zero occurrence",
          "alert_rule_ref": "mcp_upstream_config_drift"
        },
        {
          "panel_id": "gateway_a2a_stream_synthetic",
          "name": "A2A stream synthetic",
          "type": "status_history",
          "source": "synthetic_check",
          "query": "GET /api/v1/a2a/message:stream probe result",
          "alert_threshold": "401 or 5xx twice in a row",
          "synthetic_check_ref": "a2a_stream_auth",
          "alert_rule_ref": "a2a_stream_auth_regression"
        },
        {
          "panel_id": "gateway_mcp_ready_synthetic",
          "name": "MCP ready synthetic",
          "type": "status_history",
          "source": "synthetic_check",
          "query": "GET /api/v1/mcp/{provider} ready probe result",
          "alert_threshold": "3 consecutive failures for any active provider",
          "synthetic_check_ref": "mcp_provider_ready",
          "alert_rule_ref": "mcp_provider_not_ready"
        }
      ]
    },
    {
      "name": "Storage And Queue",
      "panels": [
        {
          "panel_id": "storage_artifact_write_failures",
          "name": "Artifact write failures",
          "type": "timeseries",
          "source": "workflow_logs",
          "query": "artifact write failures",
          "alert_threshold": "any sustained failure"
        },
        {
          "panel_id": "queue_invalid_messages",
          "name": "Queue invalid messages",
          "type": "timeseries",
          "source": "queue_consumer_logs",
          "query": "invalid queue message count",
          "alert_threshold": "greater than 0 in a batch"
        },
        {
          "panel_id": "queue_duplicate_rate",
          "name": "Queue duplicate rate",
          "type": "timeseries",
          "source": "queue_consumer_logs",
          "query": "duplicate processed / total processed",
          "alert_threshold": "sharp unexplained increase"
        }
      ]
    },
    {
      "name": "Deployment And Verify",
      "panels": [
        {
          "panel_id": "deploy_production_readonly_verify",
          "name": "Production readonly verify",
          "type": "status_history",
          "source": "verify_summary",
          "query": "latest readonly verify summaries",
          "alert_threshold": "2 consecutive failures",
          "synthetic_check_ref": "production_readonly_verify",
          "alert_rule_ref": "production_readonly_check_failed"
        },
        {
          "panel_id": "deploy_latest_verify_duration",
          "name": "Latest verify duration",
          "type": "timeseries",
          "source": "verify_summary",
          "query": "duration_ms from readonly and write verify summaries",
          "goal": "stable trend without sustained regression",
          "owner": "platform-release"
        }
      ]
    }
  ],
  "annotations": [
    "mark deploy timestamps",
    "mark verify timestamps",
    "mark major tenant onboarding events"
  ],
  "links": [
    {
      "label": "Observability baseline",
      "path": "docs/observability_alerting_baseline_zh.md"
    },
    {
      "label": "Observability integration manifest",
      "path": "docs/observability_integration_manifest.example.json"
    },
    {
      "label": "Ops handoff summary",
      "path": "docs/ops_handoff_summary_zh.md"
    },
    {
      "label": "Final delivery summary",
      "path": "docs/final_delivery_summary_zh.md"
    }
  ]
}
