{
  "name": "agent-control-plane",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "access:ingress:plan": "node scripts/render_access_ingress_plan.mjs",
    "github:actions:bootstrap": "node scripts/bootstrap_github_actions_runtime.mjs",
    "github:actions:inventory": "node scripts/print_github_actions_runtime_inventory.mjs",
    "post-deploy:verify": "node scripts/post_deploy_verify.mjs",
    "post-deploy:verify:readonly": "VERIFY_MODE=readonly node scripts/post_deploy_verify.mjs",
    "provisioning:submit": "node scripts/submit_provisioning_request.mjs",
    "seed:sql": "node scripts/render_seed_sql.mjs",
    "secret:rotation:bundle": "node scripts/render_secret_rotation_bundle.mjs",
    "validate:observability": "node scripts/validate_observability_examples.mjs",
    "tenant:onboarding:apply": "node scripts/apply_tenant_bundle_changes.mjs",
    "tenant:onboarding:bundle": "node scripts/render_tenant_onboarding_bundle.mjs",
    "tenant:handoff:update": "node scripts/update_tenant_handoff_state.mjs",
    "smoke": "tsc -p tsconfig.smoke.json && node .smoke-dist/scripts/smoke.js",
    "verify:build": "wrangler deploy --dry-run --env=\"\"",
    "verify:local": "npm run check && npm run smoke",
    "types": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260331.1",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.79.0"
  }
}
